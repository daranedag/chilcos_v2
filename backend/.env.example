# Variables de entorno del backend
# Copia este archivo como .env y completa los valores

# ── Base de datos (Insforge / PostgreSQL) ─────────────────────────────────────
# Insforge te provee un connection string completo en el panel.
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000

# ── CORS: orígenes permitidos (separados por coma) ───────────────────────────
# En desarrollo: http://localhost:5173
# En producción: la URL de GitHub Pages, ej. https://tu-usuario.github.io
ALLOWED_ORIGINS=http://localhost:5173,https://YOUR_GITHUB_USER.github.io
